# ── 이미지 (Pexels API) ─────────────────────────────────────────────────────
# 무료 API 키 발급: https://www.pexels.com/api/
# 없으면 NASA 공개 도메인으로 자동 fallback
PEXELS_API_KEY=your-pexels-api-key-here

# ── Supabase ────────────────────────────────────────────────────────────────
# Supabase 프로젝트 설정 > API > Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase 프로젝트 설정 > API > service_role (비밀 키 — 서버 전용)
# 절대로 클라이언트 코드나 git에 노출하지 마세요
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Supabase 웨이트리스트 테이블 DDL ────────────────────────────────────────
# Supabase SQL Editor에서 아래 쿼리를 실행하세요:
#
# CREATE TABLE waitlist (
#   id         uuid        DEFAULT gen_random_uuid() PRIMARY KEY,
#   email      text        UNIQUE NOT NULL,
#   created_at timestamptz DEFAULT now()
# );
#
# -- 이메일 인덱스 (중복 체크 성능)
# CREATE INDEX waitlist_email_idx ON waitlist (email);
